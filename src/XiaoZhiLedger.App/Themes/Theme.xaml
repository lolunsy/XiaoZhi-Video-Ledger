<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="CanvasColor">#F6F6F7</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="TextStrongColor">#17181B</Color>
    <Color x:Key="TextColor">#3D3F45</Color>
    <Color x:Key="TextMutedColor">#737780</Color>
    <Color x:Key="BorderColor">#E5E6E9</Color>
    <Color x:Key="BrandColor">#EA2323</Color>

    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextStrongBrush" Color="{StaticResource TextStrongColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BrandBrush" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="UsedBrush" Color="#3175BE" />
    <SolidColorBrush x:Key="ChipBrush" Color="#F0F1F3" />

    <Style TargetType="TextBlock">
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <Style x:Key="MetricValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MetricLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,3,0,0" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SubtlePanel" TargetType="Border">
        <Setter Property="Background" Value="#F6F7F8" />
        <Setter Property="BorderBrush" Value="#ECEDEF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="BaseButton" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.76" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.48" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource BrandBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrandBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="#DADCE0" />
        <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
    </Style>

    <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
        <Setter Property="Background" Value="#F1F2F4" />
        <Setter Property="BorderBrush" Value="#F1F2F4" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="SquareButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Width" Value="36" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ChromeBg" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ChromeBg" Property="Background" Value="#ECEDEF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ChromeBg" Property="Background" Value="#E0E1E4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BrandBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#DADCE0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="DemoCard" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#E1E2E5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Padding" Value="11" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="11" ShadowDepth="1" Direction="270" Opacity="0.07" Color="#202124" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardTitle" TargetType="TextBlock">
        <Setter Property="Margin" Value="2,11,2,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="CardMeta" TargetType="TextBlock">
        <Setter Property="Margin" Value="2,5,2,0" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="NotePlaceholder" TargetType="Border">
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="Background" Value="#F5F6F7" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="StatusText" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="18,0,0,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <Style x:Key="FooterButton" TargetType="Button" BasedOn="{StaticResource QuietButton}">
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="16,0,0,0" />
        <Setter Property="Padding" Value="11,0" />
        <Setter Property="FontSize" Value="10.5" />
    </Style>
</ResourceDictionary>
