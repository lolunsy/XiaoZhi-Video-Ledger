<Window x:Class="XiaoZhiLedger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="小智剪辑分类账"
        Width="1480" Height="900" MinWidth="1120" MinHeight="700"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI" FontSize="13"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        StateChanged="Window_StateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome x:Name="MainWindowChrome" CaptionHeight="68" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Use vector paths instead of Segoe Fluent Icons so icons render on Windows 10 and 11. -->
        <PathGeometry x:Key="FolderIconGeometry" Figures="M1,4 L6,4 L8,6 L15,6 L15,14 L1,14 Z" />
        <PathGeometry x:Key="MoreIconGeometry" Figures="M2,8 L2.01,8 M8,8 L8.01,8 M14,8 L14.01,8" />
        <PathGeometry x:Key="VideoIconGeometry" Figures="M1.5,3.5 L10.5,3.5 L10.5,12.5 L1.5,12.5 Z M10.5,6 L14.5,4.5 L14.5,11.5 L10.5,10 Z" />
        <PathGeometry x:Key="MinimizeIconGeometry" Figures="M2,8 L14,8" />
        <PathGeometry x:Key="MaximizeIconGeometry" Figures="M2.5,2.5 L13.5,2.5 L13.5,13.5 L2.5,13.5 Z" />
        <PathGeometry x:Key="RestoreIconGeometry" Figures="M5,2.5 L13.5,2.5 L13.5,11 L11,11 M2.5,5 L11,5 L11,13.5 L2.5,13.5 Z" />
        <PathGeometry x:Key="CloseIconGeometry" Figures="M3,3 L13,13 M13,3 L3,13" />
        <PathGeometry x:Key="SearchIconGeometry" Figures="M2,6.5 A4.5,4.5 0 1 1 11,6.5 A4.5,4.5 0 1 1 2,6.5 M10,10 L14,14" />
        <PathGeometry x:Key="InfoIconGeometry" Figures="M8,1.5 A6.5,6.5 0 1 1 8,14.5 A6.5,6.5 0 1 1 8,1.5 M8,7 L8,11 M8,4.5 L8,4.51" />
        <PathGeometry x:Key="EmptyIconGeometry" Figures="M2,3 L14,3 L14,13 L2,13 Z M6,6 L11,8 L6,10 Z" />

        <Style x:Key="FolderExpander" TargetType="ToggleButton">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Path x:Name="Arrow" Data="M 4,3 L 8,7 L 4,11"
                                  Stroke="#8A8E97" StrokeThickness="1.35"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Data" Value="M 3,4 L 7,8 L 11,4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Stroke" Value="#EA2323" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander" Style="{StaticResource FolderExpander}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Border x:Name="HeaderBorder" Grid.Column="1" MinHeight="29"
                                        CornerRadius="7" Background="Transparent">
                                    <Grid>
                                        <Border x:Name="Accent" Width="3" Height="17" Margin="3,0,0,0"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                CornerRadius="2" Background="{StaticResource BrandBrush}"
                                                Visibility="Collapsed" />
                                        <ContentPresenter x:Name="PART_Header" Margin="8,0,5,0"
                                                          ContentSource="Header"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                            <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#F2F3F5" />
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#C91F25" />
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#FFF0F0" />
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="FolderTemplate" ItemsSource="{Binding Children}"
                                  ItemContainerStyle="{StaticResource ModernTreeViewItem}">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Path Data="{StaticResource FolderIconGeometry}" Width="14" Height="14"
                      Stretch="Uniform" StrokeThickness="1.15" StrokeLineJoin="Round"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                      Margin="0,1,7,0" />
                <TextBlock Grid.Column="1" Text="{Binding DisplayText}" FontSize="11.5"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="MediaCardTemplate">
            <Border Width="{Binding DataContext.CardWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource DemoCard}" Margin="7">
                <StackPanel>
                    <Grid>
                        <Border Background="{Binding StatusBackground}" CornerRadius="9" Padding="9,5"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusForeground}"
                                       FontSize="11.5" FontWeight="SemiBold" />
                        </Border>
                        <Button HorizontalAlignment="Right" Style="{StaticResource SquareButton}"
                                Width="31" Height="29" Click="StatusButton_Click" ToolTip="修改状态">
                            <Path Data="{StaticResource MoreIconGeometry}" Width="14" Height="14"
                                  Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Button>
                    </Grid>
                    <Border Height="{Binding DataContext.PreviewHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0,11,0,0" CornerRadius="9" Background="#1E1F22" ClipToBounds="True"
                            MouseEnter="PreviewHost_MouseEnter" MouseMove="PreviewHost_MouseMove"
                            MouseLeave="PreviewHost_MouseLeave" MouseLeftButtonDown="PreviewHost_MouseLeftButtonDown"
                            MouseLeftButtonUp="DragSource_MouseLeftButtonUp" ToolTip="可直接把画面拖入剪映；双击打开预览">
                        <Grid>
                            <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPreviewImage}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Path Data="{StaticResource VideoIconGeometry}" Width="27" Height="27"
                                      Stretch="Uniform" Stroke="#5F626A" StrokeThickness="1.1"
                                      StrokeLineJoin="Round" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding PreviewHint}" Margin="0,8,0,0" Foreground="#8B8E96"
                                           FontSize="10.5" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"
                                    Background="#CC17181B" CornerRadius="7" Padding="7,3">
                                <TextBlock Text="{Binding ScrubPercentText}" Foreground="White" FontSize="10" />
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScrubRatio}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Border Height="4" Background="#EA2323" VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding ScrubRatio}" />
                                </Border.RenderTransform>
                            </Border>
                            <Border Background="#B2191A1D" CornerRadius="9">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreviewBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="150">
                                    <ProgressBar IsIndeterminate="True" Height="3" />
                                    <TextBlock Text="{Binding PreviewHint}" Foreground="White" FontSize="11"
                                               Margin="0,9,0,0" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitle}" ToolTip="{Binding Path}" />
                    <TextBlock Text="{Binding MetaText}" Style="{StaticResource CardMeta}" />
                    <TextBlock Text="{Binding RelativeFolder}" Margin="2,4,2,0" FontSize="10.5"
                               Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                    <Border Margin="0,10,0,0" Height="34" Background="#F5F6F7" CornerRadius="8">
                        <Grid>
                            <TextBlock Text="添加备注…" Margin="10,0" VerticalAlignment="Center"
                                       Foreground="#A0A3AA" FontSize="10.5" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Note}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="9,5" Background="Transparent" BorderThickness="0"
                                     ToolTip="备注在失去焦点后保存" LostKeyboardFocus="NoteBox_LostKeyboardFocus" />
                        </Grid>
                    </Border>
                    <Grid Margin="0,9,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="39" />
                        </Grid.RowDefinitions>
                        <Button Content="拖到剪映" Style="{StaticResource PrimaryButton}" Height="34"
                                PreviewMouseLeftButtonDown="DragButton_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="DragButton_PreviewMouseMove"
                                PreviewMouseLeftButtonUp="DragSource_MouseLeftButtonUp"
                                ToolTip="按住并拖入剪映；只有目标接受后才会计数" />
                        <Grid Grid.Row="1" Margin="0,7,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="预览" Style="{StaticResource SecondaryButton}"
                                    Height="32" Padding="7,0" Margin="0,0,4,0" Click="PreviewButton_Click" />
                            <Button Grid.Column="1" Content="定位" Style="{StaticResource SecondaryButton}"
                                    Height="32" Padding="7,0" Margin="2,0" Click="LocateButton_Click" />
                            <Button Grid.Column="2" Content="复制" Style="{StaticResource SecondaryButton}"
                                    Height="32" Padding="7,0" Margin="4,0,0,0" Click="CopyButton_Click"
                                    ToolTip="复制文件到剪贴板，可在剪映中按 Ctrl+V" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="WindowRoot" Margin="16" Background="Transparent">
        <Border x:Name="WindowShadow" Margin="1" Background="White" CornerRadius="10"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="#152238" BlurRadius="26" ShadowDepth="0" Opacity="0.18" />
            </Border.Effect>
        </Border>

        <Border x:Name="WindowKeyShadow" Margin="2" Background="White" CornerRadius="10"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="#111827" BlurRadius="10" ShadowDepth="3" Direction="270" Opacity="0.16" />
            </Border.Effect>
        </Border>

        <Border x:Name="WindowFrame" Background="{StaticResource CanvasBrush}"
                BorderBrush="#260F172A" BorderThickness="1" CornerRadius="10"
                SizeChanged="WindowFrame_SizeChanged">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="30" Height="30" Source="Assets/logo.png" Stretch="Uniform"
                           SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="小智剪辑分类账" FontSize="15.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextStrongBrush}" />
                            <TextBlock Text="v0.1.0" Margin="8,3,0,0" FontSize="9"
                                       Foreground="#989BA3" ToolTip="v0.1.0 正式版" />
                        </StackPanel>
                        <TextBlock Text="让每一条素材都有迹可循" Margin="0,1,0,0" FontSize="9.5"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="当前项目" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <ComboBox Width="196" Height="32" Margin="9,0,7,0"
                              ItemsSource="{Binding Projects}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding CurrentProject, Mode=TwoWay}"
                              IsEnabled="{Binding HasProjects}" />
                    <Button Content="新建" Style="{StaticResource SecondaryButton}" Height="32" Padding="13,0"
                            IsEnabled="{Binding CanWrite}" Click="NewProjectButton_Click" />
                    <Button Content="重命名" Style="{StaticResource QuietButton}" Height="32" Padding="13,0"
                            IsEnabled="{Binding CanWrite}" Margin="6,0,0,0" Click="RenameProjectButton_Click" />
                    <Button Content="删除" Style="{StaticResource QuietButton}" Height="32" Padding="13,0"
                            IsEnabled="{Binding CanWrite}" Margin="6,0,0,0" Click="DeleteProjectButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            Click="MinimizeButton_Click" AutomationProperties.Name="最小化">
                        <Path Data="{StaticResource MinimizeIconGeometry}" Width="12" Height="12"
                              Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25" />
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}"
                            Click="MaximizeButton_Click" AutomationProperties.Name="最大化">
                        <Path x:Name="MaximizeIconPath" Data="{StaticResource MaximizeIconGeometry}" Width="11" Height="11"
                              Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" />
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButton}" Click="CloseButton_Click"
                            AutomationProperties.Name="关闭">
                        <Path Data="{StaticResource CloseIconGeometry}" Width="11" Height="11"
                              Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="276" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="16,18,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="素材工作区" Style="{StaticResource SectionTitle}" />
                    <Border Grid.Row="1" Margin="0,12,0,0" Padding="12"
                            Style="{StaticResource SubtlePanel}">
                        <StackPanel>
                            <TextBlock Text="素材根目录" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PathInput, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,7,0,0" Height="34" Padding="8,5"
                                     ToolTip="支持本地、映射盘和 UNC/NAS 路径"
                                     KeyDown="PathInput_KeyDown" />
                            <TextBlock Text="粘贴路径后按 Enter，或使用浏览按钮。"
                                       Margin="0,5,0,0" TextWrapping="Wrap" FontSize="10.5"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                                <Button Content="载入路径" Command="{Binding LoadPathCommand}"
                                        Style="{StaticResource PrimaryButton}" Height="32" Margin="0,0,4,0" />
                                <Button Grid.Column="1" Content="浏览…" Click="BrowseButton_Click"
                                        Style="{StaticResource SecondaryButton}" Height="32" Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,20,0,10">
                        <TextBlock Text="文件夹" Style="{StaticResource SectionTitle}" />
                    </Grid>

                    <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="12" Background="#FBFBFC" Padding="6">
                        <TreeView ItemsSource="{Binding FolderRoots}" ItemTemplate="{StaticResource FolderTemplate}"
                                  ItemContainerStyle="{StaticResource ModernTreeViewItem}"
                                  Background="Transparent" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  SelectedItemChanged="FolderTree_SelectedItemChanged" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="16,10,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="素材总览" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextStrongBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding SummaryText}" Margin="12,2,8,0"
                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ViewCountText}" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,10,0" />
                        <Button Content="重新扫描" Style="{StaticResource SecondaryButton}"
                                Height="32" Padding="12,0" Command="{Binding RescanCommand}" />
                        <Button Content="重置状态" Style="{StaticResource QuietButton}"
                                Height="32" Padding="12,0" Margin="6,0,0,0"
                                IsEnabled="{Binding CanWrite}" Click="ResetStateButton_Click" />
                        <Button Content="设置 FFmpeg" Style="{StaticResource QuietButton}"
                                Height="32" Padding="12,0" Margin="6,0,0,0" Click="FfmpegButton_Click" />
                        <CheckBox Content="自动监控" IsChecked="{Binding WatchEnabled}"
                                  VerticalAlignment="Center" Margin="9,0,0,0"
                                  ToolTip="素材新增、删除或改名后自动刷新" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0,8,0,8" Padding="9,7"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="220" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Height="32" CornerRadius="8" Background="#F5F6F8"
                                BorderBrush="#ECEDEF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource SearchIconGeometry}" Width="14" Height="14"
                                      Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}" StrokeThickness="1.15"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" Padding="0"
                                         VerticalContentAlignment="Center" ToolTip="搜索文件名、备注或相对路径" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <ComboBox Width="112" Height="32" ItemsSource="{Binding StatusFilters}"
                                      SelectedItem="{Binding SelectedStatusFilter}" DisplayMemberPath="Label" />
                            <ComboBox Width="126" Height="32" Margin="7,0,0,0"
                                      ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}"
                                      DisplayMemberPath="Label" />
                            <ComboBox Width="105" Height="32" Margin="7,0,0,0"
                                      ItemsSource="{Binding CardScaleOptions}" SelectedItem="{Binding SelectedCardScale}"
                                      DisplayMemberPath="Label" />
                            <CheckBox Content="含下级" IsChecked="{Binding IncludeChildren}"
                                      VerticalAlignment="Center" Margin="9,0,2,0" ToolTip="包含下级文件夹" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#F0F1F3" CornerRadius="18" ClipToBounds="True">
                    <ScrollViewer x:Name="CardsScrollViewer" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="CardsScrollViewer_PreviewMouseWheel">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Padding="10,6" CornerRadius="9" Background="#FFF8E8"
                                    BorderBrush="#F4DEB0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource InfoIconGeometry}" Width="14" Height="14"
                                          Stretch="Uniform" Stroke="#A86B11" StrokeThickness="1.25"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding DataBannerTitle}"
                                               Margin="8,0,0,0" FontWeight="SemiBold" Foreground="#7A5317" />
                                    <TextBlock Grid.Column="2" Text="{Binding DataBannerDetail}" Margin="14,0,0,0"
                                               Foreground="#7A5317" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>

                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,16,0,0" Visibility="Collapsed">
                                <Border Style="{StaticResource DemoCard}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <Grid>
                                            <Border Background="#FCE8E8" CornerRadius="9" Padding="9,5"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="未使用 · 0 次" Foreground="#B81F27"
                                                           FontSize="11.5" FontWeight="SemiBold" />
                                            </Border>
                                            <Path Data="{StaticResource MoreIconGeometry}" Width="14" Height="14"
                                                  Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}"
                                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Right" Margin="0,6,5,0" />
                                        </Grid>
                                        <Grid Height="304" Margin="0,11,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition /><ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Border Margin="0,0,3,0" CornerRadius="9" Background="#26272B">
                                                <TextBlock Text="9:16" Foreground="#747780" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" Margin="3,0,0,0" CornerRadius="9" Background="#1E1F22">
                                                <TextBlock Text="9:16" Foreground="#676A72" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="示例素材_清晨街景_001.mp4" Style="{StaticResource CardTitle}" />
                                        <TextBlock Text="128.4 MB  ·  2026/07/15  ·  城市空镜"
                                                   Style="{StaticResource CardMeta}" />
                                        <Border Style="{StaticResource NotePlaceholder}">
                                            <TextBlock Text="添加备注…" Foreground="#9A9EA8" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource DemoCard}" Margin="5,0">
                                    <StackPanel>
                                        <Grid>
                                            <Border Background="#E7F1FF" CornerRadius="9" Padding="9,5"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="已使用 · 3 次" Foreground="#276AB3"
                                                           FontSize="11.5" FontWeight="SemiBold" />
                                            </Border>
                                            <Path Data="{StaticResource MoreIconGeometry}" Width="14" Height="14"
                                                  Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}"
                                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Right" Margin="0,6,5,0" />
                                        </Grid>
                                        <Grid Height="304" Margin="0,11,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition /><ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Border Margin="0,0,3,0" CornerRadius="9" Background="#24262A">
                                                <TextBlock Text="24%" Foreground="#71747C" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" Margin="3,0,0,0" CornerRadius="9" Background="#1B1C20">
                                                <TextBlock Text="68%" Foreground="#62656D" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="示例素材_咖啡店人物_014.mov" Style="{StaticResource CardTitle}" />
                                        <TextBlock Text="86.7 MB  ·  2026/07/14  ·  人物特写"
                                                   Style="{StaticResource CardMeta}" />
                                        <Border Style="{StaticResource NotePlaceholder}">
                                            <TextBlock Text="已用于片头氛围" Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource DemoCard}" Margin="10,0,0,0">
                                    <StackPanel>
                                        <Grid>
                                            <Border Background="#FFF1D9" CornerRadius="9" Padding="9,5"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="备选 · 已用 1 次" Foreground="#9B640D"
                                                           FontSize="11.5" FontWeight="SemiBold" />
                                            </Border>
                                            <Path Data="{StaticResource MoreIconGeometry}" Width="14" Height="14"
                                                  Stretch="Uniform" Stroke="{StaticResource TextMutedBrush}"
                                                  StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Right" Margin="0,6,5,0" />
                                        </Grid>
                                        <Grid Height="304" Margin="0,11,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition /><ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Border Margin="0,0,3,0" CornerRadius="9" Background="#292A2E">
                                                <TextBlock Text="9:16" Foreground="#747780" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Border Grid.Column="1" Margin="3,0,0,0" CornerRadius="9" Background="#202125">
                                                <TextBlock Text="9:16" Foreground="#676A72" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="示例素材_手作过程_028.mp4" Style="{StaticResource CardTitle}" />
                                        <TextBlock Text="206.2 MB  ·  2026/07/13  ·  制作过程"
                                                   Style="{StaticResource CardMeta}" />
                                        <Border Style="{StaticResource NotePlaceholder}">
                                            <TextBlock Text="节奏合适，待二选一" Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <StackPanel Grid.Row="1" Margin="0,9,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasMedia}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ItemsControl ItemsSource="{Binding VisibleMedia}"
                                              ItemTemplate="{StaticResource MediaCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <Button Content="显示更多素材" Command="{Binding LoadMoreCommand}"
                                        Margin="7,14,7,5"
                                        HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMoreMedia}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <Border Grid.Row="1" Margin="0,16,0,0" Background="White"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="15" MinHeight="420">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasMedia}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            MaxWidth="520" Margin="36">
                                    <Border Width="64" Height="64" CornerRadius="18" Background="#FFF0F0">
                                        <Path Data="{StaticResource EmptyIconGeometry}" Width="29" Height="29"
                                              Stretch="Uniform" Stroke="{StaticResource BrandBrush}" StrokeThickness="1.15"
                                              StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding EmptyStateTitle}" Margin="0,18,0,0"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextStrongBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" />
                                    <TextBlock Text="{Binding EmptyStateDetail}" Margin="0,8,0,0"
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                                        <Border Background="#F5F6F7" CornerRadius="10" Padding="11,7">
                                            <TextBlock Text="① 核对项目" FontSize="11.5" Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                        <Border Background="#F5F6F7" CornerRadius="10" Padding="11,7" Margin="8,0,0,0">
                                            <TextBlock Text="② 核对路径" FontSize="11.5" Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                        <Border Background="#F5F6F7" CornerRadius="10" Padding="11,7" Margin="8,0,0,0">
                                            <TextBlock Text="③ 下一步扫描" FontSize="11.5" Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#5BAA78" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextBrush}"
                               FontSize="11.5" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding BackupStatusText}" Style="{StaticResource StatusText}" />
                <TextBlock Grid.Column="2" Text="{Binding FfmpegStatusText}" Style="{StaticResource StatusText}" />
                <TextBlock Grid.Column="3" Text="{Binding WatchStatusText}" Style="{StaticResource StatusText}" />
                <Button Grid.Column="4" Content="{Binding UndoText}" Style="{StaticResource FooterButton}"
                        Command="{Binding UndoCommand}" />
            </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
