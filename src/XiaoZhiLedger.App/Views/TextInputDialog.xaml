<Window x:Class="XiaoZhiLedger.App.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="430" Height="220" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource CanvasBrush}" FontFamily="Microsoft YaHei UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" FontSize="13" Foreground="{StaticResource TextBrush}"
                   TextWrapping="Wrap" />
        <TextBox x:Name="ValueBox" Grid.Row="1" Margin="0,14,0,0" Height="38"
                 Padding="10,6" VerticalContentAlignment="Center" />
        <TextBlock x:Name="ErrorText" Grid.Row="2" Margin="2,7,0,0" Foreground="#B81F27"
                   FontSize="11" Visibility="Collapsed" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Width="82"
                    IsCancel="True" />
            <Button Content="确定" Style="{StaticResource PrimaryButton}" Width="82"
                    Margin="8,0,0,0" IsDefault="True" Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>
